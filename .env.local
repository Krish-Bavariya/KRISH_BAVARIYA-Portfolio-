# EmailJS Configuration for contact form
# Get these values from https://www.emailjs.com/
# These NEXT_PUBLIC_ vars are exposed to the browser (safe for EmailJS public keys)

# 1. Your EmailJS Service ID (e.g., service_xxxxxxx)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_1jrmayz

# 2. Your EmailJS Template ID (e.g., template_xxxxxxx)
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_yx4a9vq

# 3. Your EmailJS Public Key (Account > API Keys > Public Key)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=yc4M1CFWBkVDstZe8
